{
  "manifest_version": 3,
  "name": "ContextAI",
  "version": "1.0.0",
  "description": "Right-click any text, image, or video and get AI answers using your existing subscriptions.",
  "minimum_chrome_version": "114",
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage",
    "cookies",
    "identity"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://api.openai.com/*",
    "https://claude.ai/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle",
      "exclude_matches": [
        "chrome://*/*",
        "chrome-extension://*/*",
        "about://*/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "ContextAI"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/generativeai"
    ]
  }
}
